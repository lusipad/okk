{
  "name": "okclaw",
  "version": "0.1.0",
  "private": true,
  "description": "okclaw - intranet code knowledge platform",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -ws --if-present",
    "dev": "concurrently -k \"npm run dev -w @okclaw/web-backend\" \"npm run dev -w @okclaw/web-frontend\"",
    "test": "npm run test -ws --if-present",
    "lint": "npm run lint -ws --if-present",
    "release:prepare": "node scripts/prepare-release.mjs",
    "ui:pixel:baseline": "node scripts/pixel-baseline.mjs",
    "ui:pixel:audit": "node scripts/pixel-audit.mjs",
    "ui:pixel:report": "node scripts/pixel-report.mjs",
    "ui:pixel:diff": "node scripts/pixel-diff.mjs",
    "ui:pixel:reference:prepare": "node scripts/pixel-reference-prepare.mjs",
    "ui:pixel:reference-diff": "node scripts/pixel-reference-diff.mjs",
    "ui:pixel:gate": "bash scripts/pixel-gate.sh",
    "ui:pixel:gate:strict": "bash scripts/pixel-gate.sh --strict",
    "ui:pixel:reference-diff:strict": "node scripts/pixel-reference-diff.mjs --required"
  },
  "devDependencies": {
    "@types/node": "^22.13.9",
    "concurrently": "^9.1.2",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
